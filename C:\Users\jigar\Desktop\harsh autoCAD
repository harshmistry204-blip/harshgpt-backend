<!DOCTYPE html>
<html>
<head>
  <title>Advanced Calculator</title>
  <style>
    body {
      background: linear-gradient(135deg, #1e1e1e, #2c2c2c);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      font-family: Arial;
    }

    .calculator {
      background: #1e1e1e;
      padding: 15px;
      border-radius: 20px;
      width: 320px;
      box-shadow: 0 0 20px rgba(0,0,0,0.5);
    }

    #display {
      width: 100%;
      height: 70px;
      font-size: 28px;
      background: #2d2d2d;
      color: white;
      border: none;
      text-align: right;
      padding: 10px;
      border-radius: 10px;
      margin-bottom: 15px;
    }

    .buttons {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }

    button {
      height: 55px;
      font-size: 18px;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      transition: 0.2s;
      background: #3c3f41;
      color: white;
    }

    button:hover {
      transform: scale(1.05);
      background: #505354;
    }

    button:active {
      transform: scale(0.95);
    }

    .operator {
      background: #ff9500;
      color: white;
    }

    .operator:hover {
      background: #e08900;
    }

    .equal {
      background: #00c853;
      color: white;
    }

    .equal:hover {
      background: #00a844;
    }

    .clear {
      background: #d32f2f;
    }

    .clear:hover {
      background: #b71c1c;
    }
  </style>
</head>

<body>

<div class="calculator">
  <input type="text" id="display" readonly>

  <div class="buttons">
    <button onclick="percent()">%</button>
    <button class="clear" onclick="clearDisplay()">CE</button>
    <button class="clear" onclick="clearDisplay()">C</button>
    <button onclick="backspace()">⌫</button>

    <button onclick="clickValue('7')">7</button>
    <button onclick="clickValue('8')">8</button>
    <button onclick="clickValue('9')">9</button>
    <button class="operator" onclick="clickValue('*')">×</button>

    <button onclick="clickValue('4')">4</button>
    <button onclick="clickValue('5')">5</button>
    <button onclick="clickValue('6')">6</button>
    <button class="operator" onclick="clickValue('-')">−</button>

    <button onclick="clickValue('1')">1</button>
    <button onclick="clickValue('2')">2</button>
    <button onclick="clickValue('3')">3</button>
    <button class="operator" onclick="clickValue('+')">+</button>

    <button onclick="clickValue('0')">0</button>
    <button onclick="clickValue('.')">.</button>
    <button class="equal" onclick="calculate()">=</button>
  </div>
</div>

<script>
  let display = document.getElementById("display");

  function clickValue(value) {
    display.value += value;
  }

  function clearDisplay() {
    display.value = "";
  }

  function backspace() {
    display.value = display.value.slice(0, -1);
  }

  function percent() {
    try {
      display.value = eval(display.value) / 100;
    } catch {
      display.value = "Error";
    }
  }

  function calculate() {
    try {
      display.value = eval(display.value);
    } catch {
      display.value = "Error";
    }
  }

  // 🎹 Keyboard support
  document.addEventListener("keydown", function(event) {
    const key = event.key;

    if (!isNaN(key) || "+-*/.".includes(key)) {
      display.value += key;
    } else if (key === "Enter") {
      calculate();
    } else if (key === "Backspace") {
      backspace();
    } else if (key === "Escape") {
      clearDisplay();
    }
  });
</script>

</body>
</html>
